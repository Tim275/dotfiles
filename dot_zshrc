# Docker cleanup
dclean() {
  docker container prune -f
  docker image prune -f
  docker volume prune -f
  docker network prune -f
  echo "✅ Docker cleaned!"
}

# Git branch cleanup
gcleanb() {
  git fetch -p
  git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -d
  echo "✅ Stale branches cleaned!"
}

# Paste image from clipboard as file path - just type: img
img() {
  local f="/tmp/clipboard_$(date +%s).png"
  if pngpaste "$f" 2>/dev/null; then
    echo "$f"
  else
    echo "Kein Bild in Zwischenablage"
  fi
}

