kwatch() { watch -n 2 kubectl get "$@"; }

# Decode base64 secret
ksec() { kubectl get secret "$1" -o jsonpath="{.data.$2}" | base64 -d; }

# Create namespace if not exists
knsn() { kubectl get ns "$1" &>/dev/null || kubectl create ns "$1"; }

